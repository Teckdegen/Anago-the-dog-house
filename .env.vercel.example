# ─────────────────────────────────────────────────────────────
# Vercel — paste these in Project → Settings → Environment Variables
# ─────────────────────────────────────────────────────────────

# Required — /api/clmm/pools (pool list from your database)
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_secret

# Client — wallet connect (public, safe to expose)
VITE_REOWN_PROJECT_ID=your_reown_project_id

# Client — on-chain pool fee / TVL / APR reads (browser → Monad RPC)
# Use your own RPC (BlockVision, Alchemy, etc.) — public rpc.monad.xyz rate-limits browsers (HTTP 429)
VITE_MONAD_RPC_URL=https://your-private-monad-rpc.example

# Token picker balances (server route /api/blockvision in dev; on Vercel use server key)
BLOCKVISION_API_KEY=your_blockvision_api_key

# Optional Blockscout Pro key (wallet tokens + token metadata fallback)
# BLOCKSCOUT_API_KEY=

# Optional — protect /api/cron/sync-clmm-pools if you run cron on Vercel
# CRON_SECRET=your_random_secret

# ─────────────────────────────────────────────────────────────
# NOT needed on Vercel frontend (Railway bot/ indexer only)
# ─────────────────────────────────────────────────────────────
# SYNC_INTERVAL_MS=
# INDEXER_SCAN_BLOCKS=
