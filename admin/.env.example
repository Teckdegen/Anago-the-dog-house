# WalletConnect / Reown (same project id as main app is fine)
NEXT_PUBLIC_REOWN_PROJECT_ID=your_reown_project_id

# Chain: 10143 = Monad testnet, 143 = Monad mainnet
NEXT_PUBLIC_CHAIN_ID=10143

# StreamFarm contract — must match main app VITE_STREAM_FARM_* for that chain
# Testnet default (from deploySuite): 0xf14eD1b63EF380BF1d32C49fbA43b2871f194Fef
NEXT_PUBLIC_STREAM_FARM_ADDRESS=0xf14eD1b63EF380BF1d32C49fbA43b2871f194Fef
