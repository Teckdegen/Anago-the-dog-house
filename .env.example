# Uniswap Liquidity API (https://dashboard.uniswap.org) — scripts only, not VITE_
UNISWAP_API_KEY=your_key_here

# ── CLMM pool indexer (script.js) — subgraph → Supabase, runs 24/7 on your server ──
# UI only reads Supabase via /api/clmm/pools (no subgraph in the browser)
THE_GRAPH_API_KEY=your_key_here
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key
SYNC_INTERVAL_MS=900000
FULL_METRICS_SYNC=true

# ── Vercel (UI API only) — same Supabase keys, NO The Graph key needed on Vercel ──
# SUPABASE_URL=...
# SUPABASE_SERVICE_ROLE_KEY=...

# Monad chain for LP API tests/scripts (143 = mainnet, 10143 = testnet)
UNISWAP_LP_CHAIN_ID=143

# Optional — wallet used by scripts/test-uniswap-lp-api.mjs for check_approval
TEST_WALLET_ADDRESS=0x0000000000000000000000000000000000000001

# BlockVision — wallet token balances (MON + ERC-20) in TokenPicker dropdowns
# Register: https://docs.blockvision.org/
# Dev: set BLOCKVISION_API_KEY in .env.local (vite proxy hides key) OR VITE_BLOCKVISION_API_KEY for production builds
BLOCKVISION_API_KEY=your_blockvision_api_key
# VITE_BLOCKVISION_API_KEY=your_blockvision_api_key

# WalletConnect / Reown (public project id — safe to expose)
# VITE_REOWN_PROJECT_ID=your_project_id
