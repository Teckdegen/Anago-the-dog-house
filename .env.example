# Uniswap Liquidity API — scripts only, not VITE_
UNISWAP_API_KEY=your_key_here

# ── CLMM indexer (script.js on your server) ──
THE_GRAPH_API_KEY=your_key_here
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_secret
SYNC_INTERVAL_MS=300000
FULL_METRICS_SYNC=true

# ── Vercel (website API only) — add the SAME two Supabase vars below ──
# SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=your_service_role_secret

UNISWAP_LP_CHAIN_ID=143
TEST_WALLET_ADDRESS=0x0000000000000000000000000000000000000001
# Wallet token balances (locks/vesting/OTC pickers). Dev: .env.local + vite proxy. Vercel: set here (not VITE_).
BLOCKVISION_API_KEY=your_blockvision_api_key
