# Local dev — copy to .env.local

# Vercel API routes (same as Vercel production)
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_secret

# Client
VITE_REOWN_PROJECT_ID=your_reown_project_id
VITE_MONAD_RPC_URL=https://rpc.monad.xyz

BLOCKVISION_API_KEY=your_blockvision_api_key
ZERION_API_KEY=your_zerion_api_key

# Railway pool indexer (bot/) — not used by Vite dev server
RPC_URL=https://rpc.monad.xyz
SYNC_INTERVAL_MS=300000
INDEXER_SCAN_BLOCKS=50000
